# ==============================
# Telegram
# ==============================

# Telegram Bot Token from BotFather
TELEGRAM_TOKEN=your_telegram_bot_token

# Default official Telegram Bot API
TELEGRAM_API_BASE=https://api.telegram.org

# Allowed Telegram chat IDs, comma-separated.
# Leave empty for first run, then send /id to the bot and fill it in.
ADMIN_CHAT_IDS=


# ==============================
# qBittorrent
# ==============================

# You may use QBT_URL directly:
QBT_URL=http://127.0.0.1:8080

# Or let scripts generate QBT_URL from QBT_SCHEME/QBT_HOST/QBT_PORT
QBT_SCHEME=http
QBT_HOST=127.0.0.1
QBT_PORT=8080

QBT_USERNAME=admin
QBT_PASSWORD=adminadmin

# Optional qBittorrent settings
QBT_SAVE_PATH=
QBT_CATEGORY=telegram
QBT_TAGS=telegram

# false = start immediately
# true = add as stopped/paused
ADD_STOPPED=false


# ==============================
# Advanced: Local Telegram Bot API
# ==============================

USE_LOCAL_TELEGRAM_API=false

# Only used when USE_LOCAL_TELEGRAM_API=true
LOCAL_TELEGRAM_FILE_ROOT=/var/lib/telegram-bot-api
